rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow user to update their own profile OR:
      // A) Contractor/student/faculty can update a WORKER's performance metrics
      //    (task verification & reporter verification flows).
      // B) Contractor can penalize a STUDENT/FACULTY for spam flagging
      //    (only points, spam_strikes, is_flagged fields).
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        // (A) Worker performance updates
        (getUserData().role in ['contractor', 'student', 'faculty'] 
         && resource.data.role == 'worker'
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'rating', 'total_rating', 'completed_tasks_count']))
        ||
        // (B) Spam flagging penalty — contractor penalizing a student or faculty reporter
        (getUserData().role == 'contractor'
         && resource.data.role in ['student', 'faculty']
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'spam_strikes', 'is_flagged']))
      );
    }

    match /locations/{locationId} {
      allow read: if true; // Everyone can see campus locations
      allow write: if false; 
    }

    match /issues/{issueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.reporter_id == request.auth.uid
                    && request.resource.data.status == 'Reported'
                    && request.resource.data.created_at == request.time;
      
      // Allow update if:
      // 1. User is a Worker, Contractor, or Admin.
      // 2. User is the original Reporter AND they are marking the issue as 'Closed' 
      //    (and only updating allowed verification fields).
      allow update: if request.auth != null && (
        getUserData().role in ['worker', 'contractor', 'admin'] ||
        (resource.data.reporter_id == request.auth.uid 
         && request.resource.data.status == 'Closed'
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'rating_by_reporter', 'reporter_feedback', 'verified_at']))
      );
                    
      allow delete: if request.auth != null && getUserData().role == 'admin';
    }

    // Role limits and system metadata
    match /metadata/{docId} {
      allow read: if true; // Allow all to read limits (for registration validation)
      
      allow update: if request.auth != null 
                    && docId == 'roles'
                    // More robust increment check:
                    // 1. Only contractor_count changed
                    // 2. It incremented by 1
                    && request.resource.data.contractor_count == resource.data.contractor_count + 1
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contractor_count']));
      
      allow write: if false; // Deny all other direct writes
    }
  }
}
