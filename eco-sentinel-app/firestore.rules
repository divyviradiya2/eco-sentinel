rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to get user data safely. 
    // If user doc is missing (e.g. after manual deletion), returns a default object
    // to prevent rule evaluation errors.
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "none"};
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
                    && (
                      // Student/Faculty: Must have registration fields, can have spam metrics
                      (request.resource.data.role in ['student', 'faculty'] 
                       && !request.resource.data.keys().hasAny(['worker_id', 'rating', 'total_rating', 'completed_tasks_count']))
                      ||
                      // Worker/Contractor/Admin: Strictly NO spam metrics or reporter IDs
                      (request.resource.data.role in ['worker', 'contractor', 'admin']
                       && !request.resource.data.keys().hasAny(['enrollment_no', 'faculty_id', 'real_name', 'points', 'spam_strikes', 'is_flagged']))
                    );
      
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        // (A) Worker performance updates
        (getUserData().role in ['contractor', 'student', 'faculty'] 
         && resource.data.role == 'worker'
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'rating', 'total_rating', 'completed_tasks_count']))
        ||
        // (B) Spam flagging penalty
        (getUserData().role == 'contractor'
         && resource.data.role in ['student', 'faculty']
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['points', 'spam_strikes', 'is_flagged']))
      );
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if false; 
    }

    match /issues/{issueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.reporter_id == request.auth.uid
                    && request.resource.data.status == 'Reported'
                    && request.resource.data.created_at == request.time;
      
      allow update: if request.auth != null && (
        getUserData().role in ['worker', 'contractor', 'admin'] ||
        (resource.data.reporter_id == request.auth.uid 
         && request.resource.data.status == 'Closed'
         && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'rating_by_reporter', 'reporter_feedback', 'verified_at']))
      );
                    
      allow delete: if request.auth != null && getUserData().role == 'admin';
    }

    match /metadata/{docId} {
      allow read: if true;
      
      // Allow initializing roles doc if it was accidentally deleted
      allow create: if request.auth != null && docId == 'roles';

      allow update: if request.auth != null 
                    && docId == 'roles'
                    && (
                      // Case 1: Registration increment
                      (request.resource.data.contractor_count == resource.data.contractor_count + 1
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contractor_count']))
                      ||
                      // Case 2: Admin reset (safety net)
                      getUserData().role == 'admin'
                    );
      
      allow write: if false;
    }
  }
}
